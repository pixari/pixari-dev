---
import type { CollectionEntry } from 'astro:content';
import { getPostSlug } from '../../utils/posts';

interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
}

const { post, index = 0 } = Astro.props;

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/${getPostSlug(post)}/`}
  class={`blog-card reveal${index > 0 ? ` reveal-delay-${Math.min(index, 3)}` : ''}`}
>
  <span class="blog-date">{formattedDate}</span>
  <h3>{post.data.title}</h3>
  <p>{post.data.excerpt ?? post.data.description ?? ''}</p>
  {post.data.tags.length > 0 && (
    <div class="post-tags" style="margin-top:1rem;">
      {post.data.tags.slice(0, 3).map((tag) => (
        <span class="post-tag">{tag}</span>
      ))}
    </div>
  )}
</a>
