---
// Experience section
---

<section id="experience">
  <div class="section-container">
    <p class="section-label reveal">Experience</p>
    <h2 class="section-title reveal">Work history</h2>

    <div class="experience-list">
      <div class="experience-item reveal">
        <div class="exp-date">2023 – Present</div>
        <div class="exp-content">
          <h3>Senior Engineering Manager</h3>
          <div class="company">Quantilope</div>
          <p>Leading an engineering team building a consumer insights platform. AI, product, and people.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">Leadership</span>
          <span class="exp-tag">AI/ML</span>
          <span class="exp-tag">React</span>
          <span class="exp-tag">TypeScript</span>
          <span class="exp-tag">AWS</span>
        </div>
      </div>

      <div class="experience-item reveal reveal-delay-1">
        <div class="exp-date">2020 – 2023</div>
        <div class="exp-content">
          <h3>Product Engineering Manager</h3>
          <div class="company">Accenture Song</div>
          <p>Led cross-functional engineering teams on client projects. Architecture, system design, shipping production software. JavaScript, Node.js, AWS.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">JavaScript</span>
          <span class="exp-tag">Node.js</span>
          <span class="exp-tag">AWS</span>
          <span class="exp-tag">Docker</span>
          <span class="exp-tag">Scrum</span>
        </div>
      </div>

      <div class="experience-item reveal reveal-delay-2">
        <div class="exp-date">Apr 2020</div>
        <div class="exp-content">
          <h3>Course Creator</h3>
          <div class="company">DigitalDojo.it</div>
          <p>Designed and recorded a JavaScript programming course for an e-learning platform.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">JavaScript</span>
          <span class="exp-tag">E-Learning</span>
          <span class="exp-tag">Front-end Development</span>
        </div>
      </div>

      <div class="experience-item reveal">
        <div class="exp-date">2018 – 2020</div>
        <div class="exp-content">
          <h3>Senior Front-End Developer</h3>
          <div class="company">xbAV AG</div>
          <p>Built a web platform connecting insurance companies and customers. Owned the design system, migrated a React MVP, set up CI/CD.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">Vue.js</span>
          <span class="exp-tag">React</span>
          <span class="exp-tag">CI/CD</span>
          <span class="exp-tag">Design Systems</span>
        </div>
      </div>

      <div class="experience-item reveal">
        <div class="exp-date">2015 – 2018</div>
        <div class="exp-content">
          <h3>Full-Stack Developer</h3>
          <div class="company">WIGeoGIS GmbH</div>
          <p>Built geo-marketing products rendering large datasets on interactive maps. Market data, demographics, Geoserver.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">AngularJS</span>
          <span class="exp-tag">Laravel</span>
          <span class="exp-tag">Geoserver</span>
          <span class="exp-tag">Full Stack</span>
        </div>
      </div>

      <div class="experience-item reveal reveal-delay-1">
        <div class="exp-date">2013 – 2015</div>
        <div class="exp-content">
          <h3>Software Developer</h3>
          <div class="company">Safelog GmbH</div>
          <p>C# software for smart carts in warehouse logistics. Built interfaces, tested on-site in warehouses.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">C#</span>
          <span class="exp-tag">IoT</span>
          <span class="exp-tag">Logistics</span>
          <span class="exp-tag">Hardware</span>
        </div>
      </div>

      <div class="experience-item reveal reveal-delay-2">
        <div class="exp-date">2007 – 2014</div>
        <div class="exp-content">
          <h3>Founder &amp; CEO</h3>
          <div class="company">EgoRego</div>
          <p>Founded a company building web products and running digital campaigns. Managed a team, handled clients, grew the business.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">Entrepreneurship</span>
          <span class="exp-tag">Web Development</span>
          <span class="exp-tag">Project Management</span>
          <span class="exp-tag">Leadership</span>
        </div>
      </div>

      <div class="experience-item reveal">
        <div class="exp-date">2009 – 2014</div>
        <div class="exp-content">
          <h3>Teacher &amp; Academic Tutor</h3>
          <div class="company">LUMSA University, Rome</div>
          <p>Taught multimedia and online journalism at master's level. Academic tutor for web and new technologies applied to journalism.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">Teaching</span>
          <span class="exp-tag">Multimedia</span>
          <span class="exp-tag">Journalism</span>
          <span class="exp-tag">Academia</span>
        </div>
      </div>

      <div class="experience-item reveal reveal-delay-1">
        <div class="exp-date">2003 – 2005</div>
        <div class="exp-content">
          <h3>Junior Web Developer</h3>
          <div class="company">CILEA &amp; MEC Informatica, Rome</div>
          <p>Web solutions for the Italian Ministry of Education. Internal search engine for HP. C#, HTML, CSS.</p>
        </div>
        <div class="exp-tags">
          <span class="exp-tag">C#</span>
          <span class="exp-tag">HTML/CSS</span>
          <span class="exp-tag">Government</span>
          <span class="exp-tag">Enterprise</span>
        </div>
      </div>
    </div>
  </div>
</section>
