---
// About section
import { Picture } from 'astro:assets';
import profilePhoto from '../../assets/raffaele-pizzari.jpg';
---

<section id="about">
  <div class="section-container">
    <div class="about-layout">
      <div class="about-text reveal">
        <p class="section-label">About</p>
        <h2 class="section-title">The short version</h2>
        <p>
          Senior Engineering Manager at <strong>Quantilope</strong> in Munich.
          Before that, <strong>Accenture Song</strong>. Before that, startups, agencies, a company I
          founded, and a teaching gig at a university in Rome.
        </p>
        <p>
          I care about <strong>engineering leadership</strong>, <strong>AI in development</strong>,
          and building products that actually work. I write about all of it here.
          Outside of work: family, photography, chess, and side projects.
        </p>
      </div>
      <div class="about-photo reveal reveal-delay-2">
        <Picture
          src={profilePhoto}
          formats={['avif', 'webp']}
          widths={[200, 400]}
          sizes="(max-width: 600px) 150px, 200px"
          alt="Raffaele Pizzari"
          width={200}
          height={200}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
