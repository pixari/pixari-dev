---
// Hero section
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="dot"></span>
      Building in public · Munich
    </div>
    <h1>
      Raffaele<br /><span class="gradient-text">Pizzari</span>
    </h1>
    <p class="hero-subtitle">
      I build teams, ship products, and write about what makes engineering actually work.
    </p>
    <div class="hero-cta">
      <a href="#contact" class="btn btn-primary">Get in touch</a>
      <a href="#experience" class="btn btn-ghost">View experience</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-num">20+</span>
        <span class="hero-stat-label">Years shipping</span>
      </div>
      <span class="hero-stat-sep"></span>
      <div class="hero-stat">
        <span class="hero-stat-num">50+</span>
        <span class="hero-stat-label">Engineers led</span>
      </div>
      <span class="hero-stat-sep"></span>
      <div class="hero-stat">
        <span class="hero-stat-num">4</span>
        <span class="hero-stat-label">Companies</span>
      </div>
      <span class="hero-stat-sep"></span>
      <div class="hero-stat">
        <span class="hero-stat-num">3</span>
        <span class="hero-stat-label">Countries</span>
      </div>
    </div>
    <p class="cmd-hint hero-cmd-hint" onclick="window.openCmdPalette()">
      Press <kbd>⌘K</kbd> to navigate
    </p>
  </div>
</section>
