---
// Projects section
---

<section id="projects">
  <div class="section-container">
    <p class="section-label reveal">Side Projects</p>
    <h2 class="section-title reveal">Built on the side</h2>

    <div class="projects-grid">
      <div
        class="project-card reveal" data-tilt
        onmousemove="window.__updateMousePos(event, this)"
        onmouseleave="window.__resetMousePos(this)"
      >
        <div class="project-label">Side Project</div>
        <h3>BlaBla Teleprompter</h3>
          <p>Web-based teleprompter with voice-paced scrolling, smart tags, and a clean reading experience.</p>
        <a href="https://blabla.pixari.dev" class="project-link" target="_blank" rel="noopener noreferrer">
          blabla.pixari.dev <span class="arrow">→</span>
        </a>
      </div>

      <div
        class="project-card reveal reveal-delay-1"
        onmousemove="window.__updateMousePos(event, this)"
        onmouseleave="window.__resetMousePos(this)"
      >
        <div class="project-label">Side Project</div>
        <h3>MarkMySlide</h3>
          <p>Markdown-to-presentation tool. Grid layout system for dynamic slides, built with React and TypeScript.</p>
        <a href="https://markmyslide.pixari.dev" class="project-link" target="_blank" rel="noopener noreferrer">
          markmyslide.pixari.dev <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
