---
// Projects section
---

<section id="projects">
  <div class="section-container">
    <p class="section-label reveal">Fun Projects</p>
    <h2 class="section-title reveal">Things I build<br />for the love of it</h2>

    <div class="projects-grid">
      <div
        class="project-card reveal"
        onmousemove="window.__updateMousePos(event, this)"
        onmouseleave="window.__resetMousePos(this)"
      >
        <div class="project-label">Side Project</div>
        <h3>BlaBla Teleprompter</h3>
        <p>A web-based teleprompter with voice-paced scrolling, smart tags for speech markers,
          and a refined reading experience. Built from scratch through 10 iterative design cycles.</p>
        <a href="https://blabla.pixari.dev" class="project-link" target="_blank" rel="noopener noreferrer">
          blabla.pixari.dev <span class="arrow">→</span>
        </a>
      </div>

      <div
        class="project-card reveal reveal-delay-1"
        onmousemove="window.__updateMousePos(event, this)"
        onmouseleave="window.__resetMousePos(this)"
      >
        <div class="project-label">Side Project</div>
        <h3>MarkMySlide</h3>
        <p>Constraint-based grid layout system for dynamic presentations.
          Sophisticated React/TypeScript architecture with flexible slot-based composition.</p>
        <a href="https://markmyslide.pixari.dev" class="project-link" target="_blank" rel="noopener noreferrer">
          markmyslide.pixari.dev <span class="arrow">→</span>
        </a>
      </div>

      <div
        class="project-card reveal"
        onmousemove="window.__updateMousePos(event, this)"
        onmouseleave="window.__resetMousePos(this)"
      >
        <div class="project-label">Blog</div>
        <h3>pixari.dev</h3>
        <p>My personal blog where I write about engineering, AI, development practices,
          and lessons learned building products and leading teams.</p>
        <a href="/blog/" class="project-link">
          pixari.dev/blog <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
