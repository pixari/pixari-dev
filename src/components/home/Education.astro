---
// Education & Credentials section
---

<section id="education">
  <div class="section-container">
    <p class="section-label reveal">Education &amp; Credentials</p>
    <h2 class="section-title reveal">Background &amp;<br />certifications</h2>

    <div class="education-grid">
      <div class="education-list">
        <div class="education-item reveal">
          <h3>Production Cultures, Journalism &amp; Multimedia</h3>
          <div class="school">Università LUMSA, Rome</div>
          <div class="year">2005 – 2008 · Grade: 110/110</div>
        </div>
        <div class="education-item reveal reveal-delay-1">
          <h3>Communication &amp; Media Studies</h3>
          <div class="school">Università LUMSA, Rome</div>
          <div class="year">2002 – 2005 · Grade: 104/110</div>
        </div>
      </div>

      <div class="credentials-list">
        <div class="credential-item reveal">
          <div class="credential-icon">☁</div>
          <div>
            <h3>AWS Certified Developer, Associate</h3>
            <span>Amazon Web Services</span>
          </div>
        </div>
        <div class="credential-item reveal reveal-delay-3">
          <div class="credential-icon">🇮🇹</div>
          <div>
            <h3>Italian</h3>
            <span>Native or Bilingual</span>
          </div>
        </div>
        <div class="credential-item reveal reveal-delay-3">
          <div class="credential-icon">🇬🇧</div>
          <div>
            <h3>English</h3>
            <span>Full Professional</span>
          </div>
        </div>
        <div class="credential-item reveal reveal-delay-3">
          <div class="credential-icon">🇩🇪</div>
          <div>
            <h3>German</h3>
            <span>Professional Working</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
