---
import type { CollectionEntry } from 'astro:content';
import { getPostSlug } from '../../utils/posts';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const [featured, ...rest] = posts;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function readingTime(post: CollectionEntry<'blog'>) {
  return Math.max(1, Math.round((post.body ?? '').trim().split(/\s+/).length / 200));
}
---

<section id="blog">
  <div class="section-container">
    <p class="section-label reveal">Writing</p>
    <h2 class="section-title reveal">Recent thinking</h2>

    {featured && (() => {
      const featuredExcerpt = featured.data.excerpt ?? featured.data.description ?? '';
      return (
        <div class="blog-page-featured-wrap reveal">
          <a href={`/${getPostSlug(featured)}/`} class="blog-page-featured" data-tilt>
            <div class="blog-page-featured-inner">
              <div class="blog-page-featured-label">
                <span class="blog-tag-accent">Latest</span>
                <time datetime={featured.data.pubDate.toISOString()}>
                  {formatDate(featured.data.pubDate)}
                </time>
                <span class="blog-reading-time">{readingTime(featured)} min read</span>
              </div>
              <h3 class="blog-page-featured-title">
                {featured.data.title}
              </h3>
              {featuredExcerpt && (
                <p class="blog-page-featured-excerpt">{featuredExcerpt}</p>
              )}
              <div class="blog-page-featured-footer">
                {featured.data.tags.map(tag => (
                  <span class="blog-tag">{tag}</span>
                ))}
                <span class="blog-read-cta">Read →</span>
              </div>
            </div>
          </a>
        </div>
      );
    })()}

    {rest.length > 0 && (
      <div class="blog-page-list-wrap">
        {rest.map((post, i) => {
          const excerpt = post.data.excerpt ?? post.data.description ?? '';
          return (
            <a href={`/${getPostSlug(post)}/`} class={`blog-page-item reveal reveal-delay-${i + 1}`}>
              <div class="blog-page-item-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDateShort(post.data.pubDate)}
                </time>
                <span class="blog-reading-time">{readingTime(post)} min read</span>
                {post.data.tags.length > 0 && (
                  <div class="post-cats">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="blog-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="blog-page-item-body">
                <h4 class="blog-page-item-title">
                  {post.data.title}
                </h4>
                {excerpt && (
                  <p class="blog-page-item-excerpt">{excerpt}</p>
                )}
              </div>
              <span class="blog-page-item-arrow">→</span>
            </a>
          );
        })}
      </div>
    )}

    <div class="blog-more reveal">
      <a href="/blog/" class="btn btn-ghost">More writing →</a>
    </div>
  </div>
</section>
