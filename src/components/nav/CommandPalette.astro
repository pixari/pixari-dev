---
// Command palette markup — logic lives in src/scripts/command-palette.ts
---

<div class="cmd-overlay" id="cmdPalette" onclick="if(event.target===this)window.closeCmdPalette()">
  <div class="cmd-palette" role="dialog" aria-label="Command palette" aria-modal="true">
    <div class="cmd-input-wrap">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <path d="M21 21l-4.35-4.35" />
      </svg>
      <input
        class="cmd-input"
        id="cmdInput"
        type="text"
        placeholder="Type a command or search..."
        autocomplete="off"
      />
      <span class="cmd-kbd">ESC</span>
    </div>
    <div class="cmd-results" id="cmdResults"></div>
  </div>
</div>
