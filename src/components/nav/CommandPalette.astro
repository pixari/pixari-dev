---
import { getCollection } from 'astro:content';
import { getPostSlug } from '../../utils/posts';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const postData = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    slug: getPostSlug(p),
    title: p.data.title,
    desc: p.data.excerpt ?? p.data.description ?? '',
    tags: p.data.tags,
  }));
---

<div class="cmd-overlay" id="cmdPalette" onclick="if(event.target===this)window.closeCmdPalette()">
  <div class="cmd-palette" role="dialog" aria-label="Command palette" aria-modal="true">
    <div class="cmd-input-wrap">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" />
        <path d="M21 21l-4.35-4.35" />
      </svg>
      <input
        class="cmd-input"
        id="cmdInput"
        type="text"
        placeholder="Search pages, posts, actions…"
        autocomplete="off"
      />
      <span class="cmd-kbd">ESC</span>
    </div>
    <div class="cmd-results" id="cmdResults"></div>
  </div>
</div>

<!-- Post data injected at build time for client-side search -->
<script type="application/json" id="cmdPosts" set:html={JSON.stringify(postData)} />
