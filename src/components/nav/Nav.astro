---
interface Props {
  activePage?: 'home' | 'blog' | 'reading' | 'now';
}
const { activePage = 'home' } = Astro.props;
---

<header transition:persist data-pagefind-ignore>
  <nav role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo">pixari</a>
    <ul class="nav-links">
      <li><a href="/#about">About</a></li>
      <li><a href="/#experience">Experience</a></li>
      <li><a href="/blog/" class={activePage === 'blog' ? 'active' : ''}>Blog</a></li>
      <li><a href="/now/" class={activePage === 'now' ? 'active' : ''}>Now</a></li>
      <li><a href="/#projects">Fun Projects</a></li>
      <li><a href="/#game">Game</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <span class="cmd-hint" onclick="window.openCmdPalette()" aria-label="Open command palette">
      <kbd>⌘K</kbd>
    </span>
    <button class="nav-mobile-btn" onclick="window.openCmdPalette()" aria-label="Open navigation menu">
      Menu
    </button>
  </nav>
</header>
