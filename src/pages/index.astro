---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/nav/Nav.astro';
import CommandPalette from '../components/nav/CommandPalette.astro';
import Hero from '../components/home/Hero.astro';
import About from '../components/home/About.astro';
import Values from '../components/home/Values.astro';
import Experience from '../components/home/Experience.astro';
import Projects from '../components/home/Projects.astro';
import Game from '../components/home/Game.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import Publications from '../components/home/Publications.astro';
import Education from '../components/home/Education.astro';
import Testimonials from '../components/home/Testimonials.astro';
import Contact from '../components/home/Contact.astro';
import SchemaOrg from '../components/head/SchemaOrg.astro';
import '../styles/blog.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout
  title="Raffaele Pizzari — Engineering, AI & Leadership"
  description="Engineering manager in Munich. Writing about software, teams, and AI."
>
  <SchemaOrg slot="head" />

  <Nav activePage="home" />
  <CommandPalette />

  <main>
    <Hero />
    <div class="divider"></div>
    <About />
    <div class="divider"></div>
    <Values />
    <div class="divider"></div>
    <Experience />
    <div class="divider"></div>
    <BlogPreview posts={latestPosts} />
    <div class="divider"></div>
    <Projects />
    <div class="divider"></div>
    <Game />
    <div class="divider"></div>
    <Publications />
    <div class="divider"></div>
    <Education />
    <div class="divider"></div>
    <Testimonials />
    <div class="divider"></div>
    <Contact />
  </main>
</BaseLayout>

<script>
  import { initScrollReveal } from '../scripts/scroll-reveal';
  import { initAmbientGlow } from '../scripts/ambient-glow';
  import { initCommandPalette } from '../scripts/command-palette';
  import { initNav } from '../scripts/nav';
  import { initTilt } from '../scripts/tilt';
  import { initScramble } from '../scripts/scramble';
  import { initMagnetic } from '../scripts/magnetic';
  import { initParallax } from '../scripts/parallax';

  document.addEventListener('astro:page-load', () => {
    initScrollReveal();
    initAmbientGlow();
    initCommandPalette();
    initNav();
    initTilt();
    initScramble();
    initMagnetic();
    initParallax();
  });

  (window as any).__updateMousePos = (e: MouseEvent, el: HTMLElement) => {
    const rect = el.getBoundingClientRect();
    el.style.setProperty('--mouse-x', ((e.clientX - rect.left) / rect.width) * 100 + '%');
    el.style.setProperty('--mouse-y', ((e.clientY - rect.top) / rect.height) * 100 + '%');
  };

  (window as any).__resetMousePos = (el: HTMLElement) => {
    el.style.setProperty('--mouse-x', '50%');
    el.style.setProperty('--mouse-y', '50%');
  };

  (window as any).__toggleTestimonials = () => {
    const extra = document.getElementById('testimonials-extra');
    const btn = document.getElementById('testimonials-btn');
    if (!extra || !btn) return;
    const visible = extra.classList.toggle('visible');
    btn.textContent = visible ? 'Show less' : 'Show more';
    if (visible) {
      const obs = (window as any).__revealObserver;
      if (obs) extra.querySelectorAll('.reveal').forEach((el: Element) => obs.observe(el));
    }
  };
</script>
