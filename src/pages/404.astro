---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/nav/Nav.astro';
import CommandPalette from '../components/nav/CommandPalette.astro';
---

<BaseLayout
  title="404 — Page not found | pixari.dev"
  description="This page doesn't exist."
  noIndex={true}
>
  <Nav />
  <CommandPalette />

  <main class="not-found">
    <div class="not-found-inner">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title">Lost in the<br /><span class="gradient-text">stack</span></h1>
      <p class="not-found-subtitle">
        This page doesn't exist — or was deleted, renamed, or never deployed.
      </p>
      <div class="not-found-actions">
        <a href="/" class="btn btn-primary">Go home</a>
        <a href="/blog/" class="btn btn-ghost">Read the blog</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .not-found-inner {
    max-width: 560px;
  }

  .not-found-code {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(7rem, 22vw, 14rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--border);
    margin-bottom: 0;
    opacity: 0;
    animation: fadeUp 0.7s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .not-found-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-top: -0.75rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.25s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .not-found-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .not-found-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>

<script>
  import { initAmbientGlow } from '../scripts/ambient-glow';
  import { initCommandPalette } from '../scripts/command-palette';
  import { initNav } from '../scripts/nav';

  initAmbientGlow();
  initCommandPalette();
  initNav();
</script>
