---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/nav/Nav.astro';
import CommandPalette from '../components/nav/CommandPalette.astro';
import '../styles/blog.css';

const lastUpdated = 'March 2026';
---

<BaseLayout
  title="Now | pixari.dev"
  description="What I'm focused on right now."
>
  <Nav activePage="now" />
  <CommandPalette />

  <main>
    <div class="blog-page-header">
      <p class="section-label">Status</p>
      <h1 class="blog-page-title"><span class="gradient-text">Now</span></h1>
      <p class="blog-page-subtitle">
        What I'm working on right now.
      </p>
    </div>

    <div class="now-wrap">
      <p class="now-updated">Last updated: {lastUpdated} · Munich</p>

      <div class="now-section reveal">
        <p class="now-label">Building</p>
        <p class="now-text">
          Autonomous agent systems for production use. Not demos — real systems where AI
          owns parts of engineering workflows. The hard problems are boundaries, fallbacks,
          and the organizational trust needed to let agents run unsupervised.
        </p>
      </div>

      <div class="now-section reveal">
        <p class="now-label">Studying</p>
        <p class="now-text">
          AWS DevOps Professional. Infrastructure-as-code, multi-account strategy,
          incident response at scale.
        </p>
      </div>

      <div class="now-section reveal">
        <p class="now-label">Thinking about</p>
        <p class="now-text">
          Engineering culture under AI acceleration. When velocity goes up and human review
          goes down, what holds a team together? Probably <em>taste</em> — the shared sense
          of what's worth building. How to cultivate that is an open question.
        </p>
      </div>

      <p class="now-footer reveal">
        This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now page</a>.
      </p>
    </div>
  </main>
</BaseLayout>

<script>
  import { initScrollReveal } from '../scripts/scroll-reveal';
  import { initAmbientGlow } from '../scripts/ambient-glow';
  import { initCommandPalette } from '../scripts/command-palette';
  import { initNav } from '../scripts/nav';

  document.addEventListener('astro:page-load', () => {
    initScrollReveal();
    initAmbientGlow();
    initCommandPalette();
    initNav();
  });
</script>
