---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import dmSansUrl from '@fontsource/dm-sans/files/dm-sans-latin-400-normal.woff2?url';
import instrumentSerifUrl from '@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noIndex?: boolean;
  // article-specific
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const {
  title,
  description = 'Engineering manager in Munich. Writing about software, teams, and AI.',
  canonical,
  ogType = 'website',
  ogImage,
  noIndex = false,
  pubDate,
  updatedDate,
  tags = [],
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title.includes('pixari') ? title : `${title} | pixari.dev`;

// OG image: use provided image, fall back to profile photo
const defaultOgImage = new URL('/images/raffaele-pizzari.jpg', Astro.site).toString();
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).toString())
  : defaultOgImage;
const hasLargeImage = !!ogImage; // only use summary_large_image for posts with a real hero
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0c" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Raffaele Pizzari" />
    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />
    }

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="pixari.dev" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <!-- Article-specific Open Graph -->
    {ogType === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {ogType === 'article' && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {ogType === 'article' && (
      <meta property="article:author" content="https://pixari.dev/#about" />
    )}
    {ogType === 'article' && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content={hasLargeImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:site" content="@pixari" />
    <meta name="twitter:creator" content="@pixari" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <!-- Favicon & manifest -->
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>R</text></svg>"
    />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="pixari.dev blog"
      href="/rss.xml"
    />

    <!-- Preconnect: analytics -->
    <link rel="preconnect" href="https://analytics.pixari.dev" />

    <!-- Preload critical fonts -->
    <link rel="preload" href={dmSansUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={instrumentSerifUrl} as="font" type="font/woff2" crossorigin />

    <!-- Fonts: self-hosted via @fontsource (imported in frontmatter) -->

    <!-- Analytics (loaded after main thread is idle) -->
    <script is:inline>
      (function(){
        function load(){
          var s=document.createElement('script');
          s.defer=true;
          s.src='https://analytics.pixari.dev/script.js';
          s.dataset.websiteId='1018afca-a1af-4bb0-a2f1-fa53fa96c76d';
          document.head.appendChild(s);
        }
        if('requestIdleCallback' in window){requestIdleCallback(load)}
        else{setTimeout(load,2000)}
      })();
    </script>

    <ViewTransitions />
    <slot name="head" />
  </head>

  <body>
    <div class="ambient-glow" id="glow" data-pagefind-ignore></div>

    <slot />

    <footer data-pagefind-ignore>
      <p>© {new Date().getFullYear()} Raffaele Pizzari</p>
      <div class="footer-links">
        <a href="mailto:raffaele.pizzari@gmail.com" aria-label="Email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/raffaelepizzari" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://github.com/pixari" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </footer>
  </body>
</html>

<script>
  import { initCursor } from '../scripts/cursor';
  // Cursor only needs to init once; survives View Transitions
  initCursor();
</script>
